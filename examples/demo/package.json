{
  "name": "OneSignal Demo",
  "version": "0.0.1",
  "private": true,
  "description": "OneSignal Sample App",
  "scripts": {
    "setup": "../setup.sh",
    "preandroid": "vp run setup",
    "preios": "vp run setup",
    "build": "tsc && vp build",
    "android:sync": "ionic cap sync android",
    "ios:sync": "ionic cap sync ios",
    "android": "ionic cap run android -l --external",
    "ios": "ionic cap run ios -l --external",
    "update:pods": "(cd ios/App && pod update OneSignalXCFramework --no-repo-update)"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.1",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.1",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/status-bar": "^8.0.2",
    "@ionic/react": "^8.5.0",
    "@ionic/react-router": "^8.5.0",
    "@types/react-router": "^5.1.20",
    "@types/react-router-dom": "^5.3.3",
    "onesignal-cordova-plugin": "file:../../onesignal-cordova-plugin.tgz",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-icons": "^5.5.0",
    "react-router": "^5.3.4",
    "react-router-dom": "^5.3.4"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.1",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "~5.9.0"
  },
  "packageManager": "bun@1.3.13"
}
