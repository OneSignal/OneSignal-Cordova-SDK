{
  "name": "demo-no-location-spm",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "setup": "bash ./setup.sh",
    "setup:android": "bash ./setup.sh android",
    "setup:ios": "bash ./setup.sh ios",
    "clean": "vp run clean:android && vp run clean:ios && rm -rf dist",
    "clean:android": "rm -rf android/.gradle android/build android/app/build android/app/src/main/assets/public .cap-sync-android.stamp",
    "clean:ios": "rm -rf ios/App/App/public ios/App/build ios/capacitor-cordova-ios-plugins ios/App/CapApp-SPM/Package.resolved .cap-sync-ios.stamp",
    "preandroid": "vp run setup:android",
    "preios": "vp run setup:ios",
    "build": "tsc && vp build",
    "android": "ONESIGNAL_DISABLE_LOCATION=true vpx cap run android --no-sync",
    "ios": "ONESIGNAL_DISABLE_LOCATION=true vpx cap run ios --no-sync",
    "ios:resolve": "ONESIGNAL_DISABLE_LOCATION=true xcodebuild -resolvePackageDependencies -project ios/App/App.xcodeproj",
    "android:sync": "ONESIGNAL_DISABLE_LOCATION=true vpx cap sync android",
    "ios:sync": "ONESIGNAL_DISABLE_LOCATION=true vpx cap sync ios"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "onesignal-cordova-plugin": "file:../../onesignal-cordova-plugin.tgz",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "~5.9.0"
  },
  "packageManager": "bun@1.3.13"
}
